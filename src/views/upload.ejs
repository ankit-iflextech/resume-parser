<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1280">
<title>AI Resume Intelligence - Upload</title>
<script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
<link rel="stylesheet" href="/assets/css/home.css" />
<link rel="stylesheet" href="/assets/css/upload.css">
<style>
  
</style>
</head>
<body>
<nav>
  <a href="/" class="logo"><div class="logo-icon">🤖</div><div class="logo-text">Resume<span>AI</span></div></a>
  <!-- <div class="logo"><div class="logo-icon">🤖</div><div class="logo-text">Resume<span>AI</span></div></div> -->
  <div style="font-size:14px;color:#888;">Step 1 of 4 — Upload &amp; Configure</div>
</nav>
<div class="progress-bar">
  <div class="steps">
    <div class="step active" id="uploadResume"><div class="step-circle">1</div><div class="step-label">Upload Resume</div></div>
    <div class="step-line"></div>
    <div class="step pending" id="parsedResume" ><div class="step-circle">2</div><div class="step-label">Parsing</div></div>
    <div class="step-line"></div>
    <div class="step pending" id="analysisResume" ><div class="step-circle">3</div><div class="step-label">Analysis</div></div>
    <div class="step-line"></div>
    <div class="step pending" id="completeResume"><div class="step-circle">4</div><div class="step-label">Results</div></div>
  </div>
</div>
<div class="main">
  <div class="card">
    <div class="card-header">
      <div class="card-icon" style="background:#fff3e0;">📄</div>
      <div><h3>Upload Your Resume</h3><p class="sub">We support PDF, DOCX, and TXT formats</p></div>
    </div>
      <form id="analyzeForm">

        <div class="form-row">

          <!-- LEFT CARD -->
          <div class="card">
            
            <div class="drop-zone" id="dropZone">
              <input
                type="file"
                id="fileInput"
                name="resume"
                accept=".pdf,.docx,.txt"
                hidden
              />

              <div class="drop-icon">📄</div>
              <h4 id="dropText">Drop your resume here</h4>
              <p>
                or
                <span
                  class="browse-link"
                  onclick="document.getElementById('fileInput').click()"
                  >click to browse</span
                >
              </p>

              <div class="file-types">
                <span class="file-type">PDF</span>
                <span class="file-type">DOCX</span>
                <span class="file-type">TXT</span>
              </div>
            </div>

            <!-- Selected file name shows here -->
            <div class="file-info" id="fileInfo" style="display: none">
              <span class="file-name" id="fileName"></span>
              <span class="remove-file" onclick="removeFile()">✕</span>
            </div>

            <div class="input-group">
              <label>Experience Level</label>
              <select name="experience_level">
                <option value="0-2years">Entry Level (0–2 years)</option>
                <option value="2-6years">Mid-Level (2–6 years)</option>
                <option value="7+years">Senior (7+ years)</option>
              </select>
            </div>

            <div class="input-group">
              <label>Target Role (optional)</label>
              <input type="text" name="target_role" placeholder="e.g. Senior Software Engineer">
            </div>

            <div>
              <label>Select Field / Sector (optional)</label>
              <div class="tag-row">
                <label class="sector-chip"><input type="radio" name="sector" value="tech"> 💻 Technology</label>
                <label class="sector-chip"><input type="radio" name="sector" value="finance"> 💰 Finance</label>
                <label class="sector-chip"><input type="radio" name="sector" value="healthcare"> 🏥 Healthcare</label>
                <label class="sector-chip"><input type="radio" name="sector" value="education">🎓 Education</label>
                <label class="sector-chip"><input type="radio" name="sector" value="engineering">🏗️ Engineering</label>
                <label class="sector-chip"><input type="radio" name="sector" value="legal">⚖️ Legal</label>
                <label class="sector-chip"><input type="radio" name="sector" value="marketing">📈 Marketing</label>
                <label class="sector-chip"><input type="radio" name="sector" value="manufacturing">🎓 🏭 Manufacturing</label>      
              </div>
            </div>

          </div>


          <!-- RIGHT CARD -->
          <div class="card">

            <div class="card-header">
              <div class="card-icon">📝</div>
              <div>
                <h3>Job Description</h3>
                <p class="sub">Help us match you to the right opportunities</p>
              </div>
            </div>

            <div class="input-group">
              <label>Paste Job Description (optional)</label>

              <textarea name="job_description"
              placeholder="Paste the job description you're targeting here..."></textarea>
            </div>

          </div>

        </div>

        <div class="action-row">
          <button type="button" class="btn-back">← Back</button>
          <button type="submit" class="btn-analyze" id="analyzeBtn" style="cursor: not-allowed;" disabled title="Upload your resume and analysis" >🔍 Analyze Resume →</button>
        </div>

      </form>
    
  </div>
  
  
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script>
      const dropZone = document.getElementById("dropZone");
      const fileInput = document.getElementById("fileInput");
      const fileInfo = document.getElementById("fileInfo");
      const fileName = document.getElementById("fileName");
      const dropText = document.getElementById("dropText");

      // Click on drop zone opens file picker
      dropZone.addEventListener("click", () => fileInput.click());

      // File selected via input
      fileInput.addEventListener("change", () => {
        if (fileInput.files.length > 0) showFile(fileInput.files[0]);
      });

      // Drag over
      dropZone.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropZone.classList.add("dragover");
      });

      // Drag leave
      dropZone.addEventListener("dragleave", () => {
        dropZone.classList.remove("dragover");
      });

      // Drop file
      dropZone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropZone.classList.remove("dragover");
        const file = e.dataTransfer.files[0];
        if (file) {
          fileInput.files = e.dataTransfer.files; // assign to input
          showFile(file);
        }
      });

      // Show selected file
      function showFile(file) {
        fileName.textContent = file.name;
        fileInfo.style.display = "flex";
        // submitBtn.disabled = false;
        dropText.textContent = "File selected ✅";
        $("#analyzeBtn").prop("disabled", false).css("cursor", "pointer");
      }

      // Remove file
      function removeFile() {
        fileInput.value = "";
        fileInfo.style.display = "none";
        dropText.textContent = "Drop your resume here";
        $("#analyzeBtn").prop("disabled", true).css("cursor", "not-allowed");
      }
    </script>

<script>

  let animationInterval = null;

  // Start animation
  const startBtnAnimation = () => {
    $('#analyzeBtn').addClass('btn-analyzing').prop('disabled', true);
      const states = [
          '🔍 Analyzing.',
          '🔍 Analyzing..',
          '🔍 Analyzing...',
      ];
      let i = 0;
      animationInterval = setInterval(() => {
          $('#analyzeBtn').text(states[i % states.length]);
          i++;
      }, 500);
  };

  // Stop animation
  const stopBtnAnimation = (message = '✅ Done!') => {
      clearInterval(animationInterval);
      $('#analyzeBtn').removeClass('btn-analyzing');
      $('#analyzeBtn').text(message).prop('disabled', false);
  };

 $('#analyzeBtn').on('click', async (e) => {
    e.preventDefault();

    const form = document.getElementById('analyzeForm');
    const formData = new FormData(form);

    // ✅ Start animation when request begins
    startBtnAnimation();  

    try {
        const response = await fetch('/upload/analyze-resume', {
            method: 'POST',
            body: formData
        });

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        startBtnAnimation();
        while (true) {
          
            const { done, value } = await reader.read();
            if (done) break;

            const text = decoder.decode(value, { stream: true });
            const lines = text.split('\n');

            for (const line of lines) {
                if (!line.startsWith('data:')) continue;
                try {
                    const json = JSON.parse(line.replace('data:', '').trim());
                    console.log('SSE received:', json);

                    // ✅ Stop animation on completion or error
                    if (json.step === 'done' || json.status === 'complete') {
                        // stopBtnAnimation('✅ Done!');
                    }

                    if (json.step === 'error') {
                        stopBtnAnimation('❌ Try Again'); // ✅ reset on error
                    }

                    updateUI(json);
                } catch (err) {
                    console.warn('Skipping malformed line:', line);
                }
            }
        }

    } catch (err) {
        stopBtnAnimation('❌ Try Again'); // ✅ reset on fetch error
        console.error('Fetch error:', err);
    }
});
    function updateUI({ step, status, message, data}) {

        if (step === 'parse') {
            // $('#analyzeBtn').text('🔍 Analyze Resume...').animate();
            $('#uploadResume').removeClass('active').addClass('complete');
            $('#parsedResume').addClass('active');

            if(status === 'complete') {
                $('#parsedResume').addClass('complete');
            }
        }

        if (step === 'analyze') {

            $('#parsedResume').removeClass('active').addClass('complete');
            $('#analysisResume').addClass('active');

            if (status === 'complete' && data) {
                $('#analysisResume').addClass('complete');
                $('#completeResume').addClass('active').addClass('complete');
                window.location.href = `/suggestion/${data}`
            }
        }
    }

</script>
</body>
</html>
